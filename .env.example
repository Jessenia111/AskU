# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://asku:asku@localhost:5433/asku

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=8000                     # port the Express API listens on

# ─── Authentication ───────────────────────────────────────────────────────────
# Set to "true" only in local development to bypass email OTP and log in as
# the seeded dev-user-1 account. MUST be "false" in production.
DEV_AUTH=false

# ─── Security ────────────────────────────────────────────────────────────────
# Allowed frontend origin for CORS. In production, set to your domain.
CORS_ORIGIN=http://localhost:5173

# Set to "true" in production (requires HTTPS). "false" for local HTTP.
COOKIE_SECURE=false

# Secret key for emergency moderator access (fallback, prefer DB roles).
MOD_KEY=change-me-in-production

# ─── SMTP (email verification) ───────────────────────────────────────────────
# Leave blank in development — the verification code will be printed to the
# API console instead. Required for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@asku.ut.ee
APP_NAME=AskU
