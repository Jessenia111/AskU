VITE_API_BASE=http://localhost:8000

# For testing with other students on the same Wi-Fi network:
# 1. Find your computer's local IP address:
#    macOS/Linux: run `ifconfig | grep "inet "` (look for something like 192.168.x.x)
#    Windows:     run `ipconfig` (look for IPv4 Address)
# 2. Replace localhost with your IP in this file:
#    VITE_API_BASE=http://192.168.1.42:8000
# 3. Also update apps/api/.env: CORS_ORIGIN=http://192.168.1.42:5173
# 4. Start the API with:  cd apps/api && npm run dev
#    Start the web with:  cd apps/web && npm run dev
# 5. Other students open:  http://192.168.1.42:5173  in their browser
#
# For access beyond local network (internet), use ngrok:
#    npx ngrok http 5173   (for the web app)
#    npx ngrok http 8000   (for the API — update VITE_API_BASE and CORS_ORIGIN with the ngrok URLs)
